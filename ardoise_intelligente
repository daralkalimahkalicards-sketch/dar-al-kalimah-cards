            "ع": { ar: "١. ↩️ نصف دائرة صغيرة<br>٢. ↩️ نصف دائرة كبيرة", fr: "1. ↩️ Petit demi-cercle en haut<br>2. ↩️ Grand demi-cercle sous la ligne", es: "1. ↩️ Pequeño semicírculo<br>2. ↩️ Gran semicírculo" },
            "غ": { ar: "١. ↩️ نصف دائرة صغيرة<br>٢. ↩️ نصف دائرة كبيرة<br>٣. ⏺️ نقطة", fr: "1. ↩️ Petit demi-cercle<br>2. ↩️ Grand demi-cercle<br>3. ⏺️ Un point", es: "1. ↩️ Pequeño semicírculo<br>2. ↩️ Gran semicírculo<br>3. ⏺️ Un punto" },
            "ف": { ar: "١. ↻ دائرة صغيرة<br>٢. ⬇️⬅️ خط أفقي مقوس<br>٣. ⏺️ نقطة", fr: "1. ↻ Petit cercle<br>2. ⬇️⬅️ Courbe horizontale<br>3. ⏺️ Un point", es: "1. ↻ Pequeño círculo<br>2. ⬇️⬅️ Curva horizontal<br>3. ⏺️ Un punto" },
            "ق": { ar: "١. ↻ دائرة صغيرة<br>٢. ↪️ نصف دائرة<br>٣. ⏺️⏺️ نقطتان", fr: "1. ↻ Petit cercle<br>2. ↪️ Demi-cercle sous la ligne<br>3. ⏺️⏺️ Deux points", es: "1. ↻ Pequeño círculo<br>2. ↪️ Semicírculo<br>3. ⏺️⏺️ Dos puntos" },
            "ك": { ar: "١. ⬇️⬅️ خط عمودي ثم أفقي<br>٢. ✍️ همزة صغيرة", fr: "1. ⬇️⬅️ Ligne verticale puis horizontale<br>2. ✍️ Petite Hamza au milieu", es: "1. ⬇️⬅️ Línea vertical y horizontal<br>2. ✍️ Pequeña Hamza" },
            "ل": { ar: "١. ⬇️↪️ خط عمودي يشكل نصف دائرة", fr: "1. ⬇️↪️ Ligne verticale formant un demi-cercle", es: "1. ⬇️↪️ Línea vertical que forma semicírculo" },
            "م": { ar: "١. ↻ دائرة صغيرة<br>٢. ⬇️ خط ينزل للأسفل", fr: "1. ↻ Petit cercle<br>2. ⬇️ Ligne descendant sous la ligne", es: "1. ↻ Pequeño círculo<br>2. ⬇️ Línea que desciende" },
            "ن": { ar: "١. ↪️ نصف دائرة تحت السطر<br>٢. ⏺️ نقطة في الوسط", fr: "1. ↪️ Demi-cercle sous la ligne<br>2. ⏺️ Point au milieu", es: "1. ↪️ Semicírculo<br>2. ⏺️ Punto en el medio" },
            "ه": { ar: "١. ↻ دائرة داخلها دائرة صغيرة", fr: "1. ↻ Boucle avec une petite boucle à l'intérieur", es: "1. ↻ Bucle con pequeño bucle en su interior" },
            "و": { ar: "١. ↻ دائرة صغيرة<br>٢. ⤵️ خط مقوس ينزل للأسفل", fr: "1. ↻ Boucle<br>2. ⤵️ Courbe plongeante", es: "1. ↻ Bucle<br>2. ⤵️ Curva descendente" },
            "ي": { ar: "١. ↪️ شكل مقوس ينزل تحت السطر<br>٢. ⏺️⏺️ نقطتان", fr: "1. ↪️ Forme de 'S' courbé sous la ligne<br>2. ⏺️⏺️ Deux points", es: "1. ↪️ Forma de 'S' curva<br>2. ⏺️⏺️ Dos puntos" }
        };

        const letterForms = {
            "ا": ["ا", "ا", "ـا", "ـا"], "ب": ["ب", "بـ", "ـبـ", "ـب"],
            "ت": ["ت", "تـ", "ـتـ", "ـت"], "ث": ["ث", "ثـ", "ـثـ", "ـث"],
            "ج": ["ج", "جـ", "ـجـ", "ـج"], "ح": ["ح", "حـ", "ـحـ", "ـح"],
            "خ": ["خ", "خـ", "ـخـ", "ـخ"], "د": ["د", "د", "ـد", "ـد"],
            "ذ": ["ذ", "ذ", "ـذ", "ـذ"], "ر": ["ر", "ر", "ـر", "ـر"],
            "ز": ["ز", "ز", "ـز", "ـز"], "س": ["س", "سـ", "ـسـ", "ـس"],
            "ش": ["ش", "شـ", "ـشـ", "ـش"], "ص": ["ص", "صـ", "ـصـ", "ـص"],
            "ض": ["ض", "ضـ", "ـضـ", "ـض"], "ط": ["ط", "طـ", "ـطـ", "ـط"],
            "ظ": ["ظ", "ظـ", "ـظـ", "ـظ"], "ع": ["ع", "عـ", "ـعـ", "ـع"],
            "غ": ["غ", "غـ", "ـغـ", "ـغ"], "ف": ["ف", "فـ", "ـفـ", "ـف"],
            "ق": ["ق", "قـ", "ـقـ", "ـق"], "ك": ["ك", "كـ", "ـكـ", "ـك"],
            "ل": ["ل", "لـ", "ـلـ", "ـل"], "م": ["م", "مـ", "ـمـ", "ـم"],
            "ن": ["ن", "نـ", "ـنـ", "ـن"], "ه": ["ه", "هـ", "ـهـ", "ـه"],
            "و": ["و", "و", "ـو", "ـو"], "ي": ["ي", "يـ", "ـيـ", "ـي"]
        };

        const bankWords = [
            "أَسَد", "كَأْس", "مَلْجَأ", "بَاب", "كَبِير", "كِتَاب", "تَمْر", "بَيْت", "ثَوْب", "مَثَل", "بَحَث", "جَمَل", "رَجُل", "بُرْج", "حَبْل", 
            "بَحْر", "مِفْتَاح", "خُبْز", "نَخْل", "مَطْبَخ", "دُب", "مَدْرَسَة", "وَلَد", "ذَهَب", "هَذَا", "لَذِيذ", "وَرْدَة", "قَمَر", "زَيْت", "مَوْزَة", 
            "سَمَك", "مَسْجِد", "دَرْس", "شَمْس", "مِشْمِش", "عَرْش", "صَبْر", "بَصِير", "نَص", "ضَوْء", "مَرِيض", "أَرْض", "طِين", "مَطَر", "قِط", 
            "ظِل", "عَظِيم", "حَظ", "عَيْن", "مَلْعَب", "جَمْع", "غَيْم", "مَغْرِب", "صِبْغ", "فِيل", "صَيْف", "بَقَرَة", "سُوق", "مَكْتَبَة", "لَبَن", 
            "قَلَم", "جَبَل", "مَاء", "نَجْم", "عِنَب", "هِلَال", "نَهْر", "وَجْه", "وَرْد", "قَوْس", "يَد", "كُرْسِي"
        ];

        // =========================================
        // 3. LOGIQUE UI (MODES, FILIGRANE, FLÈCHES DÉTACHÉES ET AJUSTEMENT ي)
        // =========================================

        const watermark = document.getElementById('slate-watermark');
        const arrowOverlay = document.getElementById('arrow-overlay');

        function initData() {
            const lettersContainer = document.getElementById('letters-selector');
            Object.keys(strokeData).forEach(letter => {
                let btn = document.createElement('button');
                btn.className = 'letter-btn';
                btn.innerText = letter;
                btn.onclick = () => showStrokeGuide(letter, btn);
                lettersContainer.appendChild(btn);
            });

            const bankSelect = document.getElementById('bank-select');
            bankWords.forEach(word => {
                let opt = document.createElement('option');
                opt.value = word; opt.innerText = word;
                bankSelect.appendChild(opt);
            });
        }

        function setMode(mode) {
            document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
            document.getElementById('btn-mode-' + mode).classList.add('active');

            if(mode === 'letters') {
                document.getElementById('letters-selector').style.display = 'flex';
                document.getElementById('bank-selector-wrap').style.display = 'none';
                document.getElementById('stroke-guide-wrapper').style.display = 'flex';
                const firstBtn = document.querySelector('.letter-btn');
                if(firstBtn) showStrokeGuide("ا", firstBtn);
            } else {
                document.getElementById('letters-selector').style.display = 'none';
                document.getElementById('stroke-guide-wrapper').style.display = 'none';
                document.getElementById('bank-selector-wrap').style.display = 'block';
                watermark.innerText = "";
                watermark.style.transform = "translateY(0)"; // Réinitialiser le transform
                arrowOverlay.innerHTML = "";
                clearSlate();
            }
        }

        function getArrowSvg(letter) {
            const vertical = ["ا", "ط", "ظ", "ك", "ل"];
            if (vertical.includes(letter)) {
                return `<svg class="anim-arrow anim-arrow-vertical" viewBox="0 0 50 200">
                            <path d="M 25 20 L 25 170" />
                            <polygon points="15,160 35,160 25,185" />
                        </svg>`;
            } else {
                return `<svg class="anim-arrow anim-arrow-horizontal" viewBox="0 0 250 50">
                            <path d="M 230 25 L 30 25" />
                            <polygon points="45,10 45,40 20,25" />
                        </svg>`;
            }
        }
        
        function getWordArrowSvg() {
            return `<svg class="anim-arrow anim-arrow-horizontal" viewBox="0 0 250 50">
                        <path d="M 230 25 L 30 25" />
                        <polygon points="45,10 45,40 20,25" />
                    </svg>`;
        }

        function showStrokeGuide(letter, btnElement) {
            document.querySelectorAll('.letter-btn').forEach(b => b.classList.remove('active'));
            btnElement.classList.add('active');

            document.getElementById('stroke-guide-wrapper').style.display = 'flex';
            
            const guideLetter = document.getElementById('guide-letter');
            guideLetter.innerText = letter;
            
            const data = strokeData[letter];
            document.getElementById('guide-steps').innerHTML = `
                <div class="stroke-step">
                    <div class="step-ar ar-text">${data.ar}</div>
                    <div class="step-fr-es">${data.fr}<br>${data.es}</div>
                </div>
            `;
            
            const forms = letterForms[letter];
            document.getElementById('forms-grid').innerHTML = `
                <div class="form-card"><div class="ar-form">${forms[0]}</div><div class="la-form">Libre<small>Aislado</small></div></div>
                <div class="form-card"><div class="ar-form">${forms[1]}</div><div class="la-form">Début<small>Inicio</small></div></div>
                <div class="form-card"><div class="ar-form">${forms[2]}</div><div class="la-form">Milieu<small>Medio</small></div></div>
                <div class="form-card"><div class="ar-form">${forms[3]}</div><div class="la-form">Fin<small>Fin</small></div></div>
            `;
            
            watermark.style.fontSize = "16rem";
            watermark.innerText = letter;
            
            // Soulever le "ي" pour l'ajustement visuel
            if (letter === "ي") {
                guideLetter.style.transform = "translateY(-15px)";
                watermark.style.transform = "translateY(-40px)";
            } else {
                guideLetter.style.transform = "translateY(0)";
                watermark.style.transform = "translateY(0)";
            }

            arrowOverlay.innerHTML = getArrowSvg(letter);
            clearSlate();
        }

        function showBankWord(word) {
            if(!word) { watermark.innerText = ""; arrowOverlay.innerHTML = ""; return; }
            watermark.style.fontSize = "8rem";
            watermark.innerText = word;
            watermark.style.transform = "translateY(0)"; // Réinitialiser l'ajustement
            arrowOverlay.innerHTML = getWordArrowSvg();
            clearSlate();
        }

        // =========================================
        // 4. L'ARDOISE INTACTE (FIX SCROLL MOBILE)
        // =========================================
        const canvas = document.getElementById("slate-canvas");
        const ctx = canvas.getContext("2d");
        let isDrawing = false; let lastX = 0; let lastY = 0;

        function resizeCanvas() {
            canvas.width = canvas.offsetWidth; canvas.height = canvas.offsetHeight;
            ctx.lineWidth = 6; ctx.lineCap = "round"; ctx.lineJoin = "round"; ctx.strokeStyle = "#5D1828";
        }

        function getPos(e) {
            const rect = canvas.getBoundingClientRect();
            const clientX = e.touches ? e.touches[0].clientX : e.clientX;
            const clientY = e.touches ? e.touches[0].clientY : e.clientY;
            return { x: clientX - rect.left, y: clientY - rect.top };
        }

        function startPosition(e) { isDrawing = true; const pos = getPos(e); lastX = pos.x; lastY = pos.y; }
        function endPosition() { isDrawing = false; ctx.beginPath(); }
        
        function draw(e) {
            if (!isDrawing) return;
            e.preventDefault(); 
            const pos = getPos(e);
            ctx.beginPath(); ctx.moveTo(lastX, lastY); ctx.lineTo(pos.x, pos.y); ctx.stroke();
            lastX = pos.x; lastY = pos.y;
        }

        function clearSlate() { ctx.clearRect(0, 0, canvas.width, canvas.height); }

        canvas.addEventListener("mousedown", startPosition); canvas.addEventListener("mouseup", endPosition);
        canvas.addEventListener("mousemove", draw); canvas.addEventListener("mouseout", endPosition);
        
        canvas.addEventListener("touchstart", startPosition, { passive: false }); 
        canvas.addEventListener("touchend", endPosition);
        canvas.addEventListener("touchmove", draw, { passive: false });
        
        window.addEventListener("resize", resizeCanvas);

        window.onload = () => {
            initData();
            resizeCanvas();
            setTimeout(() => setMode('letters'), 100);
        };

    </script>
</body>

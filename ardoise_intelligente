            "ص": { ar: "١. ↖️➡️ حلقة بيضاوية<br>٢. ↪️ نصف دائرة", fr: "1. ↖️➡️ Boucle ovale fermée<br>2. ↪️ Grand demi-cercle sous la ligne", es: "1. ↖️➡️ Bucle ovalado<br>2. ↪️ Gran semicírculo" },
            "ض": { ar: "١. ↖️➡️ حلقة بيضاوية<br>٢. ↪️ نصف دائرة<br>٣. ⏺️ نقطة", fr: "1. ↖️➡️ Boucle ovale<br>2. ↪️ Grand demi-cercle<br>3. ⏺️ Un point", es: "1. ↖️➡️ Bucle ovalado<br>2. ↪️ Gran semicírculo<br>3. ⏺️ Un punto" },
